# FastAPI Backend
PORT=8000
ENVIRONMENT=local

# Database (PostgreSQL + PostGIS + pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=dummy_local_password
DB_NAME=pakimongo_local

# Firebase Auth (dummy for local)
FIREBASE_PROJECT_ID=dummy-project-id

# Vision / AI scoring provider: dummy | groq | google
VISION_PROVIDER=dummy
# Groq (free tier, no billing) — get a key at console.groq.com
GROQ_API_KEY=gsk_dummy_key_for_local_testing
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Google Vision (needs billing enabled even for the free tier)
GOOGLE_VISION_API_KEY=dummy_api_key_for_local_testing

# Cloud Storage (S3/GCS)
STORAGE_PROVIDER=local  # or 's3' or 'gcs'
S3_BUCKET_NAME=pakimongo-dev-bucket
S3_REGION=us-east-1
GCS_BUCKET_NAME=pakimongo-dev-bucket

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.dummy_token_for_local_testing

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
